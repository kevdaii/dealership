generator client {
    provider = "prisma-client"
    runtime  = "deno" // tells Prisma to generate Deno-compatible code
    output   = "../generated" // where the generated client goes
}

datasource db {
    provider = "postgresql" // database type
    url      = env("DATABASE_URL") // reads from .env
}

model Cars {
    id    Int     @id @default(autoincrement())
    make  String
    model String
    year  Int
    vin   String? @unique
}
